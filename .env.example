# All optional — the site runs with none of these set (serves ./docs locally).
# Every var is read at call time; features degrade cleanly when unset.

# Content
#DOCS_DIR=./docs

# Runtime git sync (production; unset = read DOCS_DIR directly)
#DOCS_GIT_REPO=https://github.com/your-org/your-docs
#DOCS_GIT_REF=main
#DOCS_GIT_SUBTREE=docs
#REPO_DIR=/data/repo
#WEBHOOK_SECRET=

# GitHub App creds for private docs repos (short-lived tokens per git op)
#GITHUB_APP_ID=
#GITHUB_APP_INSTALLATION_ID=
#GITHUB_APP_PRIVATE_KEY=

# Ask-the-docs AI chat (unset = chat hidden)
#OPENROUTER_API_KEY=
#DOCS_AI_MODEL=anthropic/claude-3.5-haiku

# Live-data SQL embeds (unset = embeds report unavailable)
#QUERY_ENGINE_URL=
#QUERY_MAX_ROWS=200
#QUERY_TIMEOUT_MS=5000

# Server
#HOST=0.0.0.0
#PORT=4321
#SHUTDOWN_GRACE_MS=10000
