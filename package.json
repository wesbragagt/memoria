{
  "name": "memoria",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "node ./dist/server/entry.mjs",
    "serve": "node server.mjs",
    "docker:build": "docker build -t memoria .",
    "check": "astro check",
    "lint": "oxlint src tests",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "verify": "astro check && npm run lint && vitest run && astro build",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/node": "^9.5.5",
    "@astrojs/react": "^4.4.2",
    "astro": "^5.18.2",
    "fast-glob": "^3.3.3",
    "hast-util-to-string": "^3.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
