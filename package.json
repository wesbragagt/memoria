    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/unist": "^3.0.3",
    "oxlint": "^1.73.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.7"
  }
