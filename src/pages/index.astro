---
// Docs home. Fresh read every request; no caching.
// Two-pane: sidebar tree + activity feed. A ?q= query is the no-JS search
// fallback and renders searchDocs results server-side in the feed area.
import Base from "../layouts/Base.astro";
import Tree from "../components/Tree.astro";
import { listDocs, buildTree, searchDocs } from "../domain/docs";

const q = (Astro.url.searchParams.get("q") ?? "").trim();

const docs = await listDocs();
const tree = buildTree(docs);

const recentlyUpdated = [...docs]
  .sort((a, b) => b.mtimeMs - a.mtimeMs)
  .slice(0, 10);

const results = q ? await searchDocs(q) : [];

const fmtDate = (ms: number) =>
  new Date(ms).toLocaleDateString(undefined, {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
---

<Base title="memoria">
  <Tree slot="tree" nodes={tree} />

  <form method="get" role="search" class="search">
    <input
      type="search"
      name="q"
      value={q}
      placeholder="Search docs…"
      aria-label="Search docs"
    />
    <button type="submit">Search</button>
  </form>

  {
    q ? (
      <section class="feed" aria-label="Search results">
        <h2>
          Results for “{q}” ({results.length})
        </h2>
        {results.length === 0 ? (
          <p class="empty">No matching docs.</p>
        ) : (
          <ul class="result-list">
            {results.map((r) => (
              <li>
                <a href={`/docs/${r.doc.slug}`} class="result-title">
                  {r.doc.title}
                </a>
                <span class="matched-in">matched in {r.matchedIn}</span>
                <p class="snippet">{r.snippet}</p>
              </li>
            ))}
          </ul>
        )}
      </section>
    ) : (
      <div class="feed">
        <section aria-label="Recently updated">
          <h2>Recently updated</h2>
          {recentlyUpdated.length === 0 ? (
            <p class="empty">No docs yet.</p>
          ) : (
            <ul class="result-list">
              {recentlyUpdated.map((d) => (
                <li>
                  <a href={`/docs/${d.slug}`} class="result-title">
                    {d.title}
                  </a>
                  <span class="date">{fmtDate(d.mtimeMs)}</span>
                </li>
              ))}
            </ul>
          )}
        </section>

        <section aria-label="Favorites" data-favorites>
          <h2>Favorites</h2>
          <p class="empty" data-empty>No favorites yet.</p>
        </section>

        <section aria-label="Recently viewed" data-recents>
          <h2>Recently viewed</h2>
          <p class="empty" data-empty>Nothing viewed yet.</p>
        </section>
      </div>
    )
  }
</Base>

<style>
  .search {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .search input {
    flex: 1;
    padding: 0.5rem 0.7rem;
    border: 1px solid var(--border, #e5e5e5);
    border-radius: 6px;
    font-size: 1rem;
  }
  .search button {
    padding: 0.5rem 1rem;
    border: 1px solid var(--border, #e5e5e5);
    border-radius: 6px;
    background: #f6f8fa;
    cursor: pointer;
  }
  .feed h2 {
    font-size: 1rem;
    margin: 1.5rem 0 0.5rem;
  }
  .result-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .result-list li {
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--border, #e5e5e5);
  }
  .result-title {
    font-weight: 600;
    text-decoration: none;
  }
  .matched-in,
  .date {
    margin-left: 0.6rem;
    font-size: 0.78rem;
    color: var(--muted, #666);
  }
  .snippet {
    margin: 0.2rem 0 0;
    font-size: 0.9rem;
    color: var(--muted, #666);
  }
  .empty {
    color: var(--muted, #666);
    font-size: 0.9rem;
  }
</style>
